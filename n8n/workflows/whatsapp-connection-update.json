{
  "name": "WhatsApp Connection Update Alert",
  "nodes": [
    {
      "id": "webhook-connection-update",
      "name": "Receive CONNECTION_UPDATE",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [250, 300],
      "webhookId": "whatsapp-connection-update",
      "parameters": {
        "httpMethod": "POST",
        "path": "whatsapp-inbound/connection-update",
        "responseMode": "onReceived",
        "options": {}
      }
    },
    {
      "id": "switch-state",
      "name": "Connection State",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [480, 300],
      "parameters": {
        "rules": {
          "rules": [
            {
              "outputKey": "disconnect",
              "conditions": {
                "options": {
                  "combinator": "or"
                },
                "conditions": [
                  {
                    "id": "condition-close",
                    "leftValue": "={{ $json.data.state }}",
                    "rightValue": "close",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  },
                  {
                    "id": "condition-connecting",
                    "leftValue": "={{ $json.data.state }}",
                    "rightValue": "connecting",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              }
            },
            {
              "outputKey": "connected",
              "conditions": {
                "options": {
                  "combinator": "and"
                },
                "conditions": [
                  {
                    "id": "condition-open",
                    "leftValue": "={{ $json.data.state }}",
                    "rightValue": "open",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              }
            }
          ]
        },
        "options": {
          "fallbackOutput": "extra"
        }
      }
    },
    {
      "id": "send-disconnect-alert",
      "name": "Send Disconnect Alert",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [720, 150],
      "parameters": {
        "method": "POST",
        "url": "=http://evolution-api:8080/message/sendText/{{ $env.EVOLUTION_INSTANCE_NAME || 'clinic-main' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.EVOLUTION_API_KEY }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"number\": \"{{ $env.ADMIN_WHATSAPP_NUMBER }}\",\n  \"text\": \"\\u26a0\\ufe0f La sesion de WhatsApp se desconecto a las {{ $now.format('yyyy-MM-dd HH:mm') }}.\\n\\nEscanea el QR para reconectar:\\nhttps://{{ $env.ADMIN_SUBDOMAIN }}.{{ $env.DOMAIN }}/WhatsApp\\n\\nEstado reportado: {{ $json.data.state }}\"\n}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "onError": "continueRegularOutput",
      "retryOnFail": false
    },
    {
      "id": "send-connection-success",
      "name": "Send Connection Success",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [720, 350],
      "parameters": {
        "method": "POST",
        "url": "=http://evolution-api:8080/message/sendText/{{ $env.EVOLUTION_INSTANCE_NAME || 'clinic-main' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.EVOLUTION_API_KEY }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"number\": \"{{ $env.ADMIN_WHATSAPP_NUMBER }}\",\n  \"text\": \"WhatsApp conectado exitosamente a las {{ $now.format('yyyy-MM-dd HH:mm') }}.\\n\\nEl chatbot y las alertas estan activos.\"\n}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "onError": "continueRegularOutput",
      "retryOnFail": false
    },
    {
      "id": "log-other-state",
      "name": "Log Other State",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [720, 500],
      "parameters": {}
    }
  ],
  "connections": {
    "Receive CONNECTION_UPDATE": {
      "main": [
        [
          {
            "node": "Connection State",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Connection State": {
      "main": [
        [
          {
            "node": "Send Disconnect Alert",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Send Connection Success",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Log Other State",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": true,
  "settings": {
    "executionOrder": "v1"
  },
  "tags": [
    {
      "name": "whatsapp"
    },
    {
      "name": "infra"
    }
  ]
}
