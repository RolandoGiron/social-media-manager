      "name": "Send WA Message",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [
        5040,
        300
      ],
      "parameters": {
        "workflowId": {
          "__rl": true,
          "value": "sub-send-wa-message",
          "mode": "name"
