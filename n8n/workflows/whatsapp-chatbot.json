        300
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE conversations\nSET state = '{{ $json.new_state }}',\n    context = '{{ $json.new_context }}'::jsonb,\n    last_message_at = now()\nWHERE id = '{{ $json.conversation_id }}'::uuid\nRETURNING id as conversation_id, state, '{{ $json.response_text.replace(/'/g, \"''\") }}'::text as response_text",
        "options": {}
      },
