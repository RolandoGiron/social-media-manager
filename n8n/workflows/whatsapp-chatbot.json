    {
      "id": "read-conversation-state",
      "name": "Read Conversation State",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        960,
        200
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT c.id, c.state, c.context, c.patient_id, c.wa_contact_id,\n       p.first_name, p.last_name, p.phone_normalized,\n       COALESCE((\n         SELECT json_agg(t ORDER BY t.created_at ASC)\n         FROM (\n           SELECT sender, content, created_at\n           FROM messages\n           WHERE conversation_id = c.id\n           ORDER BY created_at DESC\n           LIMIT 5\n         ) t\n       ), '[]'::json) AS recent_messages\nFROM conversations c\nLEFT JOIN patients p ON c.patient_id = p.id\nWHERE c.wa_contact_id = '{{ $json.remote_jid }}' AND c.state != 'closed'\nORDER BY c.last_message_at DESC NULLS LAST\nLIMIT 1",
        "options": {
          "alwaysOutputData": true
        }
      },
      "credentials": {
        "postgres": {
          "id": "postgres-credential",
          "name": "PostgreSQL"
        }
      }
    },
    {
      "id": "conversation-exists",
      "name": "Conversation Exists?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1200,
        200
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "check-id",
              "leftValue": "={{ $json.id }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      }
    },
    {
      "id": "create-conversation",
      "name": "Create New Conversation",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        1440,
        350
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH patient_match AS (\n  SELECT id FROM patients\n  WHERE phone_normalized = regexp_replace($1, '[^0-9]', '', 'g')\n  LIMIT 1\n)\nINSERT INTO conversations (wa_contact_id, state, context, patient_id)\nSELECT\n  $1,\n  'awaiting_intent',\n  '{}'::jsonb,\n  (SELECT id FROM patient_match)\nRETURNING id, state, context, patient_id, wa_contact_id, NULL::text as first_name, NULL::text as last_name, NULL::text as phone_normalized",
        "options": {
          "queryReplacement": "={{ $('Extract Message Fields').first().json.remote_jid }}"
        }
      },
      "credentials": {
        "postgres": {
          "id": "postgres-credential",
          "name": "PostgreSQL"
        }
      }
    },
    {
      "id": "merge-conversation",
      "name": "Merge Conversation Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1680,
        200
      ],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const conv = $input.item.json;\nconst msg = $('Extract Message Fields').first().json;\n\nconst buttonMap = {\n  'promo_precios': 'Quiero información sobre precios y la promoción',\n  'horarios_ubicacion': '¿Cuáles son sus horarios y dónde están ubicados?',\n  'agendar_cita': 'Quiero agendar una cita',\n  '1': 'Quiero información sobre precios y la promoción',\n  '2': '¿Cuáles son sus horarios y dónde están ubicados?',\n  '3': 'Quiero agendar una cita'\n};\n\nlet messageText = msg.message_text;\nif (msg.button_id && buttonMap[msg.button_id]) {\n  messageText = buttonMap[msg.button_id];\n} else if (buttonMap[msg.message_text?.trim()]) {\n  messageText = buttonMap[msg.message_text.trim()];\n}\n\nreturn { json: { ...conv, message_text: messageText, wa_message_id: msg.wa_message_id } };"
      }
    },
    {
      "id": "insert-inbound-message",
      "name": "Insert Inbound Message",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        1920,
        200
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO messages (conversation_id, direction, sender, content, wa_message_id)\nVALUES (\n  '{{ $json.id }}'::uuid,\n  'inbound',\n  'patient',\n  '{{ $json.message_text.replace(/'/g, \"''\") }}',\n  '{{ $json.wa_message_id }}'\n) RETURNING id",
        "options": {}
      },
      "credentials": {
        "postgres": {
          "id": "postgres-credential",
          "name": "PostgreSQL"
        }
      }
    },
    {
