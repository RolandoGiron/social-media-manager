      "typeVersion": 2,
      "position": [
        250,
        300
      ],
      "webhookId": "whatsapp-messages-upsert",
      "parameters": {
        "httpMethod": "POST",
        "path": "whatsapp-inbound/messages-upsert",
        "responseMode": "onReceived",
        "options": {}
