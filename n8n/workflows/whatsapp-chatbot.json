            "booking_context": "={{ $('Merge Conversation Data').first().json.context || {} }}",
            "patient_id": "={{ $('Merge Conversation Data').first().json.patient_id || '' }}",
            "patient_name": "={{ ($('Merge Conversation Data').first().json.first_name ? $('Merge Conversation Data').first().json.first_name + ' ' + ($('Merge Conversation Data').first().json.last_name || '') : $('Extract Message Fields').first().json.push_name) }}",
            "wa_contact_id": "={{ $('Merge Conversation Data').first().json.wa_contact_id }}",
            "remote_jid": "={{ $('Extract Message Fields').first().json.remote_jid }}",
            "instance_name": "={{ $('Extract Message Fields').first().json.instance_name }}",
            "api_key": "={{ $('Extract Message Fields').first().json.api_key }}"
          }
        }
