    {
      "id": "format-faqs",
      "name": "Format FAQs for LLM",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2880,
        400
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nconst extractFields = $('Extract Message Fields').first().json;\nconst mergedConv = $('Merge Conversation Data').first().json;\n\n// Format all FAQ rows into a single string for LLM injection\nconst formattedFaqs = items.map(item => {\n  return `[${item.json.categoria}] Q: ${item.json.pregunta}\\nA: ${item.json.respuesta}`;\n}).join('\\n---\\n');\n\n// Format conversation history from DB (last 5 messages, chronological order)\nconst recentMessages = Array.isArray(mergedConv.recent_messages) ? mergedConv.recent_messages : [];\nlet conversationHistory = 'Sin historial previo.';\nif (recentMessages.length > 0) {\n  conversationHistory = recentMessages.map(m => {\n    const role = m.sender === 'patient' ? 'Paciente' : 'Bot';\n    return `${role}: ${m.content}`;\n  }).join('\\n');\n}\n\nreturn [{\n  json: {\n    formatted_faqs: formattedFaqs || 'No hay informacion disponible en este momento.',\n    conversation_history: conversationHistory,\n    message_text: mergedConv.message_text || extractFields.message_text,\n    remote_jid: extractFields.remote_jid,\n    push_name: extractFields.push_name,\n    wa_message_id: extractFields.wa_message_id,\n    instance_name: extractFields.instance_name,\n    api_key: extractFields.api_key,\n    conversation_id: mergedConv.id,\n    conversation_state: mergedConv.state,\n    conversation_context: mergedConv.context || {}\n  }\n}];"
      }
    },
