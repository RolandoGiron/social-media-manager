      "typeVersion": 2,
      "position": [
        2400,
        300
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "check-booking-state",
              "leftValue": "={{ $('Merge Conversation Data').item.json.state }}",
              "rightValue": "booking_flow",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      }
    },
    {
      "id": "booking-sub-workflow-mid",
      "name": "Continue Booking Flow",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [
        2640,
        200
      ],
      "parameters": {
        "workflowId": {
          "__rl": true,
          "value": "sub-booking-flow",
          "mode": "name"
        },
        "options": {
          "waitForSubWorkflow": true
        },
        "workflowInputs": {
          "schema": [
            {
              "name": "message_text",
              "type": "string"
            },
            {
              "name": "booking_context",
              "type": "object"
            },
            {
              "name": "patient_id",
              "type": "string"
            },
            {
              "name": "patient_name",
              "type": "string"
            },
            {
              "name": "wa_contact_id",
              "type": "string"
            },
            {
              "name": "remote_jid",
              "type": "string"
            },
            {
              "name": "instance_name",
              "type": "string"
            },
            {
              "name": "api_key",
              "type": "string"
            }
          ],
          "mappingMode": "defineBelow",
          "value": {
            "message_text": "={{ $('Extract Message Fields').item.json.message_text }}",
            "booking_context": "={{ $('Merge Conversation Data').item.json.context || {} }}",
            "patient_id": "={{ $('Merge Conversation Data').item.json.patient_id || '' }}",
            "patient_name": "={{ ($('Merge Conversation Data').item.json.first_name ? $('Merge Conversation Data').item.json.first_name + ' ' + ($('Merge Conversation Data').item.json.last_name || '') : $('Extract Message Fields').item.json.push_name) }}",
            "wa_contact_id": "={{ $('Merge Conversation Data').item.json.wa_contact_id }}",
            "remote_jid": "={{ $('Extract Message Fields').item.json.remote_jid }}",
            "instance_name": "={{ $('Extract Message Fields').item.json.instance_name }}",
            "api_key": "={{ $('Extract Message Fields').item.json.api_key }}"
          }
        }
      }
    },
    {
      "id": "booking-after-mid-flow",
      "name": "Prepare Mid-Booking State Update",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2880,
        200
      ],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $input.item.json;\nconst convData = $('Merge Conversation Data').first().json;\nconst extractFields = $('Extract Message Fields').first().json;\n\nreturn {\n  json: {\n    response_text: item.response_text || '',\n    new_state: item.new_state || 'booking_flow',\n    new_context: item.new_context || '{}',\n    conversation_id: convData.id,\n    remote_jid: extractFields.remote_jid,\n    instance_name: extractFields.instance_name,\n    api_key: extractFields.api_key\n  }\n};"
      }
    },
    {
      "id": "load-knowledge-base",
      "name": "Load Knowledge Base",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        2640,
        400
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT pregunta, respuesta, categoria FROM knowledge_base WHERE is_active = true ORDER BY categoria",
        "options": {}
      },
      "credentials": {
        "postgres": {
          "id": "postgres-credential",
          "name": "PostgreSQL"
        }
      }
    },
    {
      "id": "format-faqs",
      "name": "Format FAQs for LLM",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2880,
        400
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nconst extractFields = $('Extract Message Fields').first().json;\nconst mergedConv = $('Merge Conversation Data').first().json;\n\n// Format all FAQ rows into a single string for LLM injection\nconst formattedFaqs = items.map(item => {\n  return `Q: ${item.json.pregunta}\\nA: ${item.json.respuesta}`;\n}).join('\\n---\\n');\n\nreturn [{\n  json: {\n    formatted_faqs: formattedFaqs || 'No hay informacion disponible en este momento.',\n    message_text: extractFields.message_text,\n    remote_jid: extractFields.remote_jid,\n    push_name: extractFields.push_name,\n    wa_message_id: extractFields.wa_message_id,\n    instance_name: extractFields.instance_name,\n    api_key: extractFields.api_key,\n    conversation_id: mergedConv.id,\n    conversation_state: mergedConv.state,\n    conversation_context: mergedConv.context || {}\n  }\n}];"
      }
    },
    {
      "id": "classify-intent",
