      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO messages (conversation_id, direction, sender, content)\nVALUES (\n  '{{ $('Merge All Response Paths').item.json.conversation_id }}'::uuid,\n  'outbound',\n  'bot',\n  '{{ $('Merge All Response Paths').item.json.response_text.replace(/'/g, \"''\") }}'\n) RETURNING id",
        "options": {}
