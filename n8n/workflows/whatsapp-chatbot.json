      ],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// DEBUG NODE: Makes send params visible in execution log.\n// Reads from Merge All Response Paths (the node that has remote_jid, response_text, etc.)\n// before Postgres nodes stripped them out.\nconst mergeData = $('Merge All Response Paths').first().json;\n\nconst remote_jid = mergeData.remote_jid || '';\nconst response_text = mergeData.response_text || '';\nconst instance_name = mergeData.instance_name || '';\nconst api_key = mergeData.api_key || '';\n\n// If any param is empty, log it clearly so you can see in execution log\nif (!remote_jid) console.error('DEBUG ERROR: remote_jid is empty!');\nif (!response_text) console.error('DEBUG ERROR: response_text is empty!');\nif (!instance_name) console.error('DEBUG ERROR: instance_name is empty!');\nif (!api_key) console.error('DEBUG ERROR: api_key is empty!');\n\nconsole.log('DEBUG send params:', JSON.stringify({ remote_jid, response_text: response_text.substring(0, 50), instance_name }));\n\nreturn { json: { remote_jid, response_text, instance_name, api_key } };"
