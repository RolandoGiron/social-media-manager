    {
      "id": "a1b2c3d4-0009-0009-0009-000000000009",
      "name": "Render 24h Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1500, 300],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $input.item.json;\nconst template = $('Fetch Reminder Template').first().json;\n\n// Format date/time in America/Mexico_City\nconst tz = 'America/Mexico_City';\nconst dt = new Date(item.scheduled_at);\n\nconst dtMX = new Intl.DateTimeFormat('es-MX', {\n  timeZone: tz,\n  weekday: 'long',\n  day: 'numeric',\n  month: 'long',\n  hour: '2-digit',\n  minute: '2-digit',\n  hour12: true\n});\n\nconst parts = dtMX.formatToParts(dt);\nconst get = (type) => parts.find(p => p.type === type)?.value ?? '';\n\nconst fecha = `${get('weekday')} ${get('day')} de ${get('month')}`;\nconst hora = `${get('hour')}:${get('minute')} ${get('dayPeriod')}`;\n\nlet body = template.body\n  .replace(/\\{\\{nombre\\}\\}/gi, item.nombre || '')\n  .replace(/\\{\\{tipo\\}\\}/gi, item.appointment_type || '')\n  .replace(/\\{\\{fecha\\}\\}/gi, fecha)\n  .replace(/\\{\\{hora\\}\\}/gi, hora);\n\nreturn [{ json: { ...item, rendered_message: body } }];"
      }
    },
    {
      "id": "a1b2c3d4-0010-0010-0010-000000000010",
      "name": "Render 1h Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1500, 440],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $input.item.json;\nconst template = $('Fetch Reminder Template').first().json;\n\n// Format date/time in America/Mexico_City\nconst tz = 'America/Mexico_City';\nconst dt = new Date(item.scheduled_at);\n\nconst dtMX = new Intl.DateTimeFormat('es-MX', {\n  timeZone: tz,\n  weekday: 'long',\n  day: 'numeric',\n  month: 'long',\n  hour: '2-digit',\n  minute: '2-digit',\n  hour12: true\n});\n\nconst parts = dtMX.formatToParts(dt);\nconst get = (type) => parts.find(p => p.type === type)?.value ?? '';\n\nconst fecha = `${get('weekday')} ${get('day')} de ${get('month')}`;\nconst hora = `${get('hour')}:${get('minute')} ${get('dayPeriod')}`;\n\nlet body = template.body\n  .replace(/\\{\\{nombre\\}\\}/gi, item.nombre || '')\n  .replace(/\\{\\{tipo\\}\\}/gi, item.appointment_type || '')\n  .replace(/\\{\\{fecha\\}\\}/gi, fecha)\n  .replace(/\\{\\{hora\\}\\}/gi, hora);\n\nreturn [{ json: { ...item, rendered_message: body } }];"
      }
    },
