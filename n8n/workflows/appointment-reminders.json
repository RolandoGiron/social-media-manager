    {
      "id": "a1b2c3d4-0005-0005-0005-000000000005",
      "name": "Query 24h Appointments",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [1000, 300],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n    a.id AS appointment_id,\n    a.scheduled_at,\n    a.appointment_type,\n    p.first_name AS nombre,\n    p.phone_normalized AS phone\nFROM appointments a\nJOIN patients p ON a.patient_id = p.id\nWHERE a.status = 'confirmed'\n  AND a.reminder_24h_sent = false\n  AND a.scheduled_at BETWEEN NOW() + INTERVAL '23 hours 45 minutes'\n                         AND NOW() + INTERVAL '24 hours 15 minutes'",
        "options": {}
      },
      "credentials": {
        "postgres": {
          "id": "postgres-credential",
          "name": "PostgreSQL"
        }
      }
    },
    {
      "id": "a1b2c3d4-0006-0006-0006-000000000006",
      "name": "Query 1h Appointments",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [1000, 440],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n    a.id AS appointment_id,\n    a.scheduled_at,\n    a.appointment_type,\n    p.first_name AS nombre,\n    p.phone_normalized AS phone\nFROM appointments a\nJOIN patients p ON a.patient_id = p.id\nWHERE a.status = 'confirmed'\n  AND a.reminder_1h_sent = false\n  AND a.scheduled_at BETWEEN NOW() + INTERVAL '45 minutes'\n                         AND NOW() + INTERVAL '1 hour 15 minutes'",
        "options": {}
      },
      "credentials": {
        "postgres": {
          "id": "postgres-credential",
          "name": "PostgreSQL"
        }
