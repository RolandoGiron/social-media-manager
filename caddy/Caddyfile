{
    email {$ACME_EMAIL:admin@example.com}
}

{$N8N_SUBDOMAIN:n8n}.{$DOMAIN:localhost} {
    reverse_proxy n8n:5678
}

{$EVOLUTION_SUBDOMAIN:wa}.{$DOMAIN:localhost} {
    reverse_proxy evolution-api:8080
}

{$ADMIN_SUBDOMAIN:admin}.{$DOMAIN:localhost} {
    basic_auth {
        {$ADMIN_USER:admin} {$ADMIN_PASSWORD_HASH}
    }

    handle_path /uploads/* {
        root * /srv/uploads
        file_server
        header Content-Disposition "inline"
        header Cache-Control "public, max-age=31536000, immutable"
        header X-Content-Type-Options "nosniff"
    }

    reverse_proxy streamlit:8501
}
