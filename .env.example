# === Domain Configuration ===
DOMAIN=example.com
N8N_SUBDOMAIN=n8n
EVOLUTION_SUBDOMAIN=wa
ADMIN_SUBDOMAIN=admin

# === PostgreSQL ===
POSTGRES_DB=clinic_crm
POSTGRES_USER=clinic
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# === n8n ===
N8N_ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# === Evolution API ===
EVOLUTION_API_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# === Caddy Basic Auth (for Streamlit admin UI) ===
# Generate hash with: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-password'
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=CHANGE_ME_USE_caddy_hash-password

# === Caddy ACME (Let's Encrypt) ===
ACME_EMAIL=admin@example.com

# === WhatsApp Session (Phase 2) ===
EVOLUTION_INSTANCE_NAME=clinic-main
ADMIN_WHATSAPP_NUMBER=+50312345678
CLINIC_WHATSAPP_NUMBER=+50387654321

# === Phase 6: Social Media Publishing ===
# Set to "false" only after Meta App Review is approved AND the Instagram Business
# account is linked to the Facebook Page that owns the access token configured in n8n.
# When true, social-publish workflow logs the call and marks status=published without
# touching Meta Graph API. Safe for local dev and pre-approval staging.
MOCK_SOCIAL=true

# Meta Graph API credentials (required when MOCK_SOCIAL=false)
META_PAGE_ACCESS_TOKEN=CHANGE_ME_META_PAGE_ACCESS_TOKEN
META_IG_USER_ID=CHANGE_ME_INSTAGRAM_USER_ID
META_FB_PAGE_ID=CHANGE_ME_FACEBOOK_PAGE_ID
