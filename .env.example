# ============================================================
# AI Social Media Manager — Environment Variables
# Copy to .env and fill all values before deploying
# ============================================================

# ---- Domain ------------------------------------------------
# Base domain (Hostinger VPS hostname or your custom domain)
DOMAIN=srv1533829.hstgr.cloud

# Existing n8n instance hostname on this VPS (DO NOT change unless you moved n8n)
N8N_HOST=n8n-dlyc.srv1533829.hstgr.cloud

# Subdomains for services managed by this project
EVOLUTION_SUBDOMAIN=wa
ADMIN_SUBDOMAIN=admin

# Kept for local dev Caddy compatibility
N8N_SUBDOMAIN=n8n

# ---- PostgreSQL --------------------------------------------
POSTGRES_DB=clinic_crm
POSTGRES_USER=clinic
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ---- n8n Encryption Key ------------------------------------
# Only needed if you run n8n from this project's compose (local dev).
# Production n8n is already running separately — leave blank or use its key.
N8N_ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# ---- Evolution API (WhatsApp) ------------------------------
EVOLUTION_API_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
EVOLUTION_INSTANCE_NAME=clinic-main

# ---- WhatsApp Numbers --------------------------------------
ADMIN_WHATSAPP_NUMBER=+50312345678
CLINIC_WHATSAPP_NUMBER=+50387654321

# ---- Admin UI Basic Auth (Traefik htpasswd format) ---------
# Generate with:
#   docker run --rm httpd:2.4-alpine htpasswd -nbB admin "your_password"
# Paste the output directly here — $ signs do NOT need escaping in .env files.
ADMIN_AUTH=admin:CHANGE_ME_run_htpasswd_command_above

# Kept for local dev Caddy compatibility
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=CHANGE_ME_USE_caddy_hash-password
ACME_EMAIL=admin@example.com

# ---- Social Media ------------------------------------------
# Set to "false" only after Meta App Review is approved and Instagram Business
# account is linked. true = logs calls without touching Meta API (safe for dev).
MOCK_SOCIAL=true

# Meta Graph API credentials (required when MOCK_SOCIAL=false)
META_PAGE_ACCESS_TOKEN=CHANGE_ME_META_PAGE_ACCESS_TOKEN
META_IG_USER_ID=CHANGE_ME_INSTAGRAM_USER_ID
META_FB_PAGE_ID=CHANGE_ME_FACEBOOK_PAGE_ID
